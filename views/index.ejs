<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collaborative drawing!</title>
    <link rel="icon" type="image/x-icon" href="/images/default/icon.ico">
    <style>
        body{
            background: #f8f9fa;
        }
    </style>
</head>
<body>
    <%- include('./partial/header.ejs',{dot:".",mainCheck:true}) %>
    <div class="album py-5 bg-body-tertiary"> 
        <div class="container"> 
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3"> 
                <% for (let i = 0; i < publImg.length; i++) { %>
                    <div class="col"> 
                        <div class="card shadow-sm "> 
                            <img src="<%= publImg[i].dUrl %>" >
                            <div class="card-body"> 
                                <h1 class="card-text"><%= publImg[i].name %></h1>
                                <p class="card-text"><%= publImg[i].desc %></p>
                                <div class="d-flex justify-content-between align-items-center"> 
                                    <div class="btn-group"> 
                                        <a type="button" class="btn btn-sm btn-outline-secondary" href="./imageView/<%= publImg[i].url %>">View</a> 
                                        <% if(publImg[i].visibility==0) { %>
                                        <a type="button" class="btn btn-sm btn-outline-secondary" href="./image/<%= publImg[i].url %>">edit</a>
                                        <% } %>
                                    </div> 
                                    <!-- <small class="text-body-secondary">9 mins</small>  -->
                                </div>
                            </div> 
                        </div> 
                    </div> 
                    
                <% } %>
                
            </div>
        </div>
    </div>
</body>
</html>