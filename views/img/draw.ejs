<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= imgName %></title>
    <link rel="icon" type="image/x-icon" href="/images/default/icon.ico">
    <link rel="stylesheet" href="/drawing/style/stils.css">
</head>
<body>
    <%- include('../partial/header.ejs',{dot:"..",lan:lan}) %>
    <div class="hidden" id="imgData"><%=c%></div>
    <div id="color" class="canv"><canvas width="0" height="0"></canvas></div>
    <div id="moveable" class="controlP" style="top:200px;left:200px">
        <input type="color" id="lol" value="#ff0000" class="colChoo">
        <div class="toolBox">
            <a id="pencil" class="tIcon"></a>
            <a id="bucket" class="tIcon"></a>
            <a id="moveView" class="tIcon"></a>
        </div>
        <button class="saveBtn btn btn-secondary" onclick="saveImage()">
            <% if (lan=="lv") { %>
            Saglabāt
            <% } else { %>
            Save
            <% } %>
        </button>
        <label for="toolOption" class="form-label">Pencil size <input type="number" value="2" id="num"></label>
        
        <input type="range" class="form-range" min="1" max="100" id="toolOption">
    </div>
    
    <script src="/drawing/scr/draw.js"></script>
    <script src="/drawing/scr/init.js"></script>
    <script src="/drawing/scr/webCon.js"></script>
</body>
</html>