
<!DOCTYPE HTML>  
<html>
    <head>
        <link href="./theme/default.css?v=<%=time%>" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
        <style>
        .error {color: #FF0000;}
        </style>
    </head>
    <body class="d-flex align-items-center py-6 bg-body-tertiary">
        <script>
            if ( window.history.replaceState ) {
                window.history.replaceState( null, null, window.location.href );
            }
        </script>

        <main class="form-signin w-25 m-auto">
            <form method="post" action="<%=self%>">
                <img class="mb-4" src="./first_img.png?v=<%=time%>" alt="" width="25" height="25">
                <h1 class="h3 mb-3 fw-normal">Sign in</h1>
                <input type="hidden" value="<%=rand%>" name="randcheck" />
                <div class="form-floating">
                <input type="text" name="name" value="<%=name%>" class="form-control" id="floatingInput" placeholder="name@example.com">
                <label for="floatingInput">Email or Username</label>
                <span class="error"><%=nameErr%></span>
                </div>
                <div class="form-floating">
                <input type="password" name="pass" value="<%=pass%>" class="form-control" id="floatingPassword" placeholder="Password">
                <label for="floatingPassword">Password</label>
                <span class="error"><%=passErr%></span>
                </div>

                <!-- <div class="form-check text-start my-3">
                <input class="form-check-input" type="checkbox" value="remember-me" id="flexCheckDefault">
                <label class="form-check-label" for="flexCheckDefault">
                    Remember me
                </label>
                </div> -->
                <div class="d-flex">
                    <button class="btn btn-primary w-75 py-2" type="submit" name="submit" value="Submit">Sign in</button>
                    <a class="btn btn-secondary w-25 py-2" href="./register">Register</a>
                </div>
            </form>
        </main>

    </body>
</html>

